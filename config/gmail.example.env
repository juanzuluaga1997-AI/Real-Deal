# Gmail integration configuration
# Copy these values into your local environment file or hosting provider secrets.
# Do not commit real OAuth credentials or mailbox addresses.

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Optional legacy/manual token. The in-app Connect Gmail flow writes a local private token instead.
GMAIL_REFRESH_TOKEN=
# Use 0 for all available Gmail history.
GMAIL_SYNC_LOOKBACK_DAYS=0
# Use 0 to sync all matched messages in the selected lookback window.
GMAIL_SYNC_MAX_MESSAGES_PER_CONTACT=0
