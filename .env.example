# Real Deal local environment
# Copy this file to .env.local and fill in private values locally.
# Never commit .env.local, OAuth credentials, refresh tokens, or mailbox addresses.

# Daily recommendations use this timezone to decide the current app date.
REAL_DEAL_TIME_ZONE=America/New_York

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Optional legacy/manual token. The in-app Connect Gmail flow stores a local private token instead.
GMAIL_REFRESH_TOKEN=

# Use 0 for all available Gmail history.
GMAIL_SYNC_LOOKBACK_DAYS=0

# Use 0 to sync all matched messages in the selected lookback window.
GMAIL_SYNC_MAX_MESSAGES_PER_CONTACT=0

# Optional Supabase configuration for the Lovable transition.
# These values are not required for the current deterministic prototype.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
